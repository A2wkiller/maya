{
  "name": "maya-v2",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron": "electron .",
    "electron:dev": "taskkill /f /im electron.exe 2>nul & concurrently \"npm run dev\" \"wait-on --timeout 60000 http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "next build && next export && electron-builder",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.99.3",
    "@types/nodemailer": "^7.0.11",
    "auto-launch": "^5.0.6",
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.1",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "node-notifier": "^10.0.1",
    "nodemailer": "^8.0.3",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.58.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@electron/remote": "^2.1.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.0.1",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.maya.personal",
    "productName": "MAYA Personal AI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MAYA"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json"
    ]
  }
}
