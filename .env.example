# MAYA Personal AI OS - Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub

# Required - Google Gemini (vision + AI)
# Get free key: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_KEY=your_gemini_key_here

# Required - Groq (fast AI + Whisper voice)
# Get free key: https://console.groq.com
NEXT_PUBLIC_GROQ_KEY=your_groq_key_here

# Required - Supabase (database + memory)
# Get free: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON=your_supabase_anon_key_here

# Optional - ElevenLabs (premium voice)
# Get free tier: https://elevenlabs.io
NEXT_PUBLIC_ELEVENLABS_KEY=

# Optional - Local controller token (keep same on Electron + Python)
NEXT_PUBLIC_MAYA_AGENT_TOKEN=maya_local_token
